<table class="table borderless">
  <thead>
    <tr>
      <th class="text-right">Position</th>
      <th>Tournament</th>
      <th class="text-right">Points</th>
    </tr>
  </thead>
  <tbody>
  <% player.placings.sort_by { |each| each.edition.end_date }.reverse.each do |placing| %>
      <tr>
        <td width="100px" class="text-right"><%= placing.name %></td>
        <td><%= link_to placing.edition.name, placing.edition %></td>
        <td class="text-right"><%= Rankings.points_for(placing) %> pts</td>
      </tr>
  <% end %>
  </tbody>
</table>